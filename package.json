{
    "name": "misska",
    "version": "1.0.0",
    "type": "module",
    "bin": {
        "misska": "./dist/src/misskey-cli.js"
    },
    "scripts": {
        "dev": "tsx src/misskey-cli.tsx",
        "build": "tsc -p .",
        "prepack": "npm run build",
        "start": "node dist/src/misskey-cli.js",
        "lint": "eslint 'src/**/*.{ts,tsx}'",
        "test": "jest --passWithNoTests"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "misskey",
        "cli",
        "terminal"
    ],
    "author": "SuperSandyman",
    "license": "ISC",
    "description": "A CLI client for Misskey",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SuperSandyman/misska.git"
    },
    "bugs": {
        "url": "https://github.com/SuperSandyman/misska/issues"
    },
    "homepage": "https://github.com/SuperSandyman/misska#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "eslint": "^10.5.0",
        "jest": "^30.4.2",
        "prettier": "^3.8.4",
        "ts-jest": "^29.4.11",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "conf": "^15.1.0",
        "ink": "^7.1.0",
        "ink-select-input": "^6.2.0",
        "ink-text-input": "^6.0.0",
        "keytar": "^7.9.0",
        "misskey-js": "^2026.6.0-beta.0",
        "react": "^19.2.7",
        "undici": "^8.5.0",
        "ws": "^8.21.0",
        "zustand": "^5.0.14"
    },
    "overrides": {
        "js-yaml": "^4.2.0"
    }
}
